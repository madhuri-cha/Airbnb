<%- include('../partials/head') %>

</head>

<body>

<%- include('../partials/nav', { isLoggedIn: isLoggedIn, userType: null, currentPage: 'signup' }) %>

<main class="container mx-auto mt-8 p-8 bg-white rounded-lg shadow-md">

  <h1 class="text-3xl font-bold mb-6 text-center text-gray-800">
    Register as new user
  </h1>

  <form action="/signup" method="POST" class="max-w-md mx-auto">

    <% if (errorMessages && errorMessages.length > 0) { %>

      <div class="mb-4">

        <% errorMessages.forEach(error => { %>

          <p class="text-red-500">
            <%= error %>
          </p>

        <% }) %>

      </div>

    <% } %>

    <input
      type="text"
      name="username"
      placeholder="Enter your username"
      value="<%= oldInput.username %>"
      class="w-full px-4 py-2 mb-4 border rounded-md"
      required
    />

    <input
      type="email"
      name="email"
      placeholder="test@pop.com"
      value="<%= oldInput.email %>"
      class="w-full px-4 py-2 mb-4 border rounded-md"
      required
    />

    <input
      type="password"
      name="password"
      placeholder="Enter password"
      class="w-full px-4 py-2 mb-4 border rounded-md"
      required
    />

    <input
      type="password"
      name="confirmPassword"
      placeholder="Confirm password"
      class="w-full px-4 py-2 mb-4 border rounded-md"
      required
    />

    <div class="mb-4">

      <p>User Type:</p>

      <label>

        <input
          type="radio"
          name="userType"
          value="host"
          <%= oldInput.userType === 'host' ? 'checked' : '' %>
        />

        Host

      </label>

      <label class="ml-4">

        <input
          type="radio"
          name="userType"
          value="guest"
          <%= oldInput.userType === 'guest' ? 'checked' : '' %>
        />

        Guest

      </label>

    </div>

    <div class="mb-4">

      <input
        type="checkbox"
        id="terms"
        name="terms"
        required
      />

      <label for="terms">

        I agree to the Terms and Conditions

      </label>

    </div>

    <input
      type="submit"
      value="Register"
      class="w-full bg-red-500 text-white py-2 rounded-md"
    />

  </form>

</main>
<%- include('../partials/footer') %>
</body>
</html>